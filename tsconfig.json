{
    "compilerOptions": {
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2018",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "strict": true,
        "lib": ["DOM", "ES2020"]
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"]
}
