{
  "name": "obsidian-daily-echoes",
  "version": "1.0.1",
  "private": true,
  "description": "Revisit your daily notes from previous years: on this day, this week, this month, or this day of the month.",
  "keywords": [
    "daily-notes",
    "journal",
    "obsidian",
    "obsidian-plugin",
    "on-this-day"
  ],
  "license": "GPL-3.0-or-later",
  "author": "Wojciech Polak",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "./scripts/install-to-vault.sh --build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:versions": "node scripts/check-versions.mjs",
    "check": "npm run check:versions && npm run lint && npm run format:check && npm run build && npm run test",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "esbuild": "^0.28.1",
    "moment": "^2.30.1",
    "obsidian": "latest",
    "obsidian-daily-notes-interface": "^0.9.5",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
